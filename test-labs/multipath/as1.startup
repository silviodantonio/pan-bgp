sysctl -w net.ipv6.conf.all.seg6_enabled=1
# sysctl -w net.ipv6.conf.all.forwarding=1

ip addr add 192.0.2.2/30 dev eth0
ip addr add 192.0.2.5/30 dev eth1
ip addr add 192.0.2.17/30 dev eth2
ip addr add 198.51.100.1/24 dev eth3

ip addr add 203.0.113.1/32 dev lo

ip link add srv6-sids type dummy
ip link set srv6-sids up

ip -6 addr add 2001:0db8:1:1::1/64 dev srv6-sids
ip -6 route add 2001:db8:1:1::100 encap seg6local action End table main dev srv6-sids
ip -6 route add 2001:db8:1:1::200 encap seg6local action End.DT6 table main dev srv6-sids

systemctl start frr

systemctl start panbgpd_node
