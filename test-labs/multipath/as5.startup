sysctl -w net.ipv6.conf.all.seg6_enabled=1

ip -6 addr add dd04::2/16 dev eth0
ip -6 addr add dd05::1/16 dev eth1
ip -6 addr add cc::05/16 dev eth2

# this is a hack for getting a BGP id
ip addr add 10.0.0.5/8 dev lo

# define dummy interface for managing SRv6 SIDs
ip link add srv6-sids type dummy
ip link set srv6-sids up

ip -6 addr add aa05::1/64 dev srv6-sids
ip -6 route add aa05::100 encap seg6local action End table main dev srv6-sids
ip -6 route add aa05::200 encap seg6local action End.DT6 table main dev srv6-sids

# ip -6 addr add aa05::1/64 dev lo
# ip -6 route add aa05::100 encap seg6local action End table main dev lo
# ip -6 route add aa05::200 encap seg6local action End.DT6 table main dev lo

systemctl start frr
systemctl start panbgpd_node
